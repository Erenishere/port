# PostgreSQL is the canonical store for chat sessions, leads, transcripts, and outbox events.
DATABASE_URL="postgresql://webnexus:replace-me@localhost:5432/webnexus?sslmode=prefer"

# Use a separate, disposable database. Never point this at production.
TEST_DATABASE_URL="postgresql://webnexus_test:webnexus_test@localhost:5432/webnexus_test?sslmode=prefer"

# Existing delivery endpoint. The worker sends a stable Idempotency-Key header.
LEAD_WEBHOOK_URL="https://example.invalid/webnexus/leads"

# Transactional outbox controls.
LEAD_OUTBOX_MAX_ATTEMPTS=5
LEAD_OUTBOX_BASE_DELAY_MS=1000
LEAD_OUTBOX_MAX_DELAY_MS=60000
LEAD_OUTBOX_LEASE_MS=30000
LEAD_OUTBOX_POLL_MS=1000

# Explicitly opt into volatile storage only for tests or local UI experiments.
WEBNEXUS_USE_IN_MEMORY_REPOSITORY=false
